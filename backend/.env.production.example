# =================================================================
# 🛍️ REVITAL ECOMMERCE - PRODUCCIÓN
# =================================================================
# Copia como .env.production. Se carga cuando ENVIRONMENT=production.
# Usar solo en despliegues de producción.

ENVIRONMENT=production
MOCK_MODE=false

# Base de datos de producción (no usar localhost)
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_bd

# URLs del frontend (dominio real)
FRONTEND_URL=https://tu-dominio.revital.cloud
VERIFY_EMAIL_URL=https://tu-dominio.revital.cloud/verify-email
RESET_PASSWORD_URL=https://tu-dominio.revital.cloud/reset-password

# Resend: dominio verificado y API key de producción
RESEND_FROM_EMAIL=noreply@tudominio.com
RESEND_FROM_NAME=Tu Tienda

# Wompi: claves de producción (no usar pub_test_ / prv_test_)
WOMPI_PUBLIC_KEY=pub_prod_xxxx
WOMPI_PRIVATE_KEY=prv_prod_xxxx
WOMPI_EVENTS_SECRET=events_secret_prod
WOMPI_INTEGRITY_SECRET=integrity_secret_prod
WOMPI_ENVIRONMENT=production

# Cloudinary: cuenta de producción
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# OpenAI: API key y modelo para IA en producción
OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_MODEL=gpt-4o-mini
