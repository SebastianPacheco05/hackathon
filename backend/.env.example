# =================================================================
# 🛍️ REVITAL - SaaS ECOMMERCE CONFIGURATION (base)
# =================================================================
# Copia como .env. Luego usa .env.development o .env.production según
# el entorno (ENVIRONMENT=development|production). El backend carga
# primero .env y después .env.development o .env.production.
# Ver .env.development.example y .env.production.example.

# =================================================================
# 🏢 CONFIGURACIÓN DE LA EMPRESA (SaaS Configurable)
# =================================================================
# Estas variables permiten personalizar la marca para cada cliente

# Nombre de la empresa cliente
COMPANY_NAME=Brillo Rosa

# Nombre de la aplicación (puede ser igual al de la empresa)
APP_NAME=Brillo Rosa

# Eslogan o tagline de la empresa
COMPANY_TAGLINE=Tu tienda de belleza online

# Dirección física de la empresa
COMPANY_ADDRESS=Av. Principal 123, Ciudad Bella, País

# Email de soporte al cliente
SUPPORT_EMAIL=soporte@brillorosa.com

# =================================================================
# 🔐 CONFIGURACIÓN DE SEGURIDAD
# =================================================================
# Configuraciones críticas para la seguridad de la aplicación

# Clave secreta para JWT (generar una nueva para cada instalación)
SECRET_KEY=tu_clave_secreta_super_segura_aqui

# Algoritmo de encriptación para JWT
ALGORITHM=HS256

# Tiempo de expiración de tokens de acceso (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Tiempo de expiración de tokens de refresh (en días)
REFRESH_TOKEN_EXPIRE_DAYS=7

# =================================================================
# 🗄️ CONFIGURACIÓN DE BASE DE DATOS
# =================================================================
# URL de conexión a la base de datos PostgreSQL

DATABASE_URL=postgresql://usuario:password@localhost/nombre_bd

# =================================================================
# 📧 CONFIGURACIÓN DE RESEND (Servicio de Email)
# =================================================================
# Configuración para el envío de emails transaccionales

# API Key de Resend (obtener en resend.com)
RESEND_API_KEY=re_tu_api_key_de_resend_aqui

# Email remitente (debe estar verificado en Resend)
RESEND_FROM_EMAIL=noreply@brillorosa.com

# Nombre del remitente que aparecerá en los emails
RESEND_FROM_NAME="Brillo Rosa"

# =================================================================
# 🌐 CONFIGURACIÓN DE FRONTEND
# =================================================================
# URLs del frontend para enlaces en emails

# URL principal del sitio web
FRONTEND_URL=https://www.brillorosa.live

# URL para verificación de email (con parámetro ?token=)
VERIFY_EMAIL_URL=https://www.brillorosa.live/verify

# URL para reset de contraseña (con parámetro ?token=)
RESET_PASSWORD_URL=https://www.brillorosa.live/reset-password

# Cloudinary Service
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenAI (IA Admin)
OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_MODEL=gpt-4o-mini

# =================================================================
# 🔧 CONFIGURACIÓN DE DESARROLLO LOCAL
# =================================================================
# Variables para desarrollo y testing local

# Para testing local sin dominio, usar:
# RESEND_FROM_EMAIL=onboarding@resend.dev
# FRONTEND_URL=http://localhost:3000
# VERIFY_EMAIL_URL=http://localhost:3000/verify
# RESET_PASSWORD_URL=http://localhost:3000/reset-password

# =================================================================
# 📋 INSTRUCCIONES DE CONFIGURACIÓN
# =================================================================
# 1. Copia este archivo como .env
# 2. Copia .env.development.example como .env.development (dev) y/o
#    .env.production.example como .env.production (prod)
# 3. ENVIRONMENT=development (por defecto) usa .env.development;
#    en producción exporta ENVIRONMENT=production para usar .env.production
# 4. Reinicia el servidor después de cambiar variables 
