# =================================================================
# 🛍️ REVITAL ECOMMERCE - DESARROLLO
# =================================================================
# Copia como .env.development. Se carga cuando ENVIRONMENT=development
# (por defecto). Valores típicos para desarrollo local.

ENVIRONMENT=development
MOCK_MODE=false

# Base de datos local
DATABASE_URL=postgresql://usuario:password@localhost:5432/revital_ecommerce

# URLs del frontend (localhost)
FRONTEND_URL=http://localhost:3000
VERIFY_EMAIL_URL=http://localhost:3000/verify-email
RESET_PASSWORD_URL=http://localhost:3000/reset-password

# Resend: para pruebas usar dominio de Resend
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Dev Store

# Wompi: claves de sandbox/test
WOMPI_PUBLIC_KEY=pub_test_xxxx
WOMPI_PRIVATE_KEY=prv_test_xxxx
WOMPI_EVENTS_SECRET=test_events_xxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxx
WOMPI_ENVIRONMENT=sandbox

# Cloudinary: usar cuenta de desarrollo o dejar las que tengas
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# OpenAI: API key y modelo para consultas de IA
OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_MODEL=gpt-4o-mini