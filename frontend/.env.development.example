# =============================================================================
# REVITAL ECOMMERCE FRONTEND - DESARROLLO
# =============================================================================
# Copia como .env.development. Next.js lo carga automáticamente con `pnpm dev`
# (NODE_ENV=development).

# API del backend (local o remota en dev)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Bypass de auth frontend para demos con backend en MOCK_MODE
NEXT_PUBLIC_MOCK_AUTH_BYPASS=false

# Wompi sandbox
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_xxxx
