Table tab_comentarios {
  id_comentario decimal [not null, pk]
  product_id decimal [not null, pk, ref: > tab_products.id]
  id_usuario decimal [not null, ref: > tab_usuarios.id_usuario]
  id_orden decimal [not null, ref: > tab_ordenes.id_orden]
  comentario varchar [not null]
