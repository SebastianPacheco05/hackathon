  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

// ========== Órdenes y pagos ==========

Table tab_ordenes {
  id_orden decimal [pk]
  fec_pedido timestamp [not null]
  id_usuario decimal [not null, ref: > tab_usuarios.id_usuario]
  val_total_productos decimal [not null]
  val_total_descuentos decimal [not null, default: 0]
  val_total_pedido decimal [not null]
  ind_estado decimal [not null, default: 1]
  metodo_pago varchar
  id_descuento decimal [ref: > tab_descuentos.id_descuento]
  detalle_descuentos_aplicados json
  des_observaciones varchar
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_pagos {
  id_pago serial [pk]
  id_orden decimal [not null, ref: > tab_ordenes.id_orden]
  reference varchar
  provider_transaction_id varchar
  provider_name varchar [not null, default: 'wompi']
  status varchar [not null]
  status_detail varchar
  amount decimal [not null]
  currency_id varchar [not null, default: 'COP']
  installments int
  payment_method_type varchar
  payment_method_extra jsonb
  fee_amount decimal [default: 0]
  net_received_amount decimal
  provider_date_created timestamp
  provider_date_approved timestamp
  raw_response jsonb
  raw_last_event jsonb
  parent_payment_id int [ref: > tab_pagos.id_pago]
  estado_procesamiento varchar [default: 'pendiente']
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_orden_productos {
  id_orden_producto decimal [pk]
  id_orden decimal [not null, ref: > tab_ordenes.id_orden]
  variant_id decimal [not null, ref: > tab_product_variant_combinations.id]
  cant_producto int [not null]
  precio_unitario_orden decimal [not null]
  subtotal decimal [not null]
  opciones_elegidas jsonb [not null]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

