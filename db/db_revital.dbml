// ========== Estadísticas, CMS, Favoritos ==========

Table tab_estadisticas_productos {
  product_id decimal [pk, ref: - tab_products.id]
  nom_producto varchar
  precio_actual decimal
  stock_actual int
  producto_activo boolean
  total_ordenes int [default: 0]
  total_unidades_vendidas int [default: 0]
  total_ingresos decimal [default: 0]
  ventas_mes_actual int [default: 0]
  ingresos_mes_actual decimal [default: 0]
  ventas_mes_anterior int [default: 0]
  ingresos_mes_anterior decimal [default: 0]
  promedio_venta_mensual decimal [default: 0]
  promedio_ingreso_mensual decimal [default: 0]
  precio_promedio_venta decimal [default: 0]
