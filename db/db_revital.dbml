Project RevitalDB {
  database_type: 'PostgreSQL'
  Note: 'Base de datos e-commerce Revital - catálogo, usuarios, órdenes, fidelización'
}

// ========== Registro y catálogo base ==========

Table tab_reg_del {
  id_del serial [pk]
  tab_name varchar [not null]
  atributos jsonb [not null]
  usr_delete varchar [not null]
  fec_delete timestamp [not null]
}

Table tab_categories {
  id decimal [pk]
  name varchar [not null]
  slug varchar [not null, unique]
  parent_id decimal [ref: > tab_categories.id]
  is_active boolean [default: true]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_attributes {
  id decimal [pk]
  name varchar [not null]
  data_type varchar [not null]
  has_predefined_values boolean [default: false]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_attribute_values {
  id decimal [pk]
  attribute_id decimal [not null, ref: > tab_attributes.id]
  value varchar [not null]
  hex_color varchar
  sort_order int [default: 0]
  is_active boolean [default: true]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_category_attributes {
  id decimal [pk]
  category_id decimal [not null, ref: > tab_categories.id]
  attribute_id decimal [not null, ref: > tab_attributes.id]
  is_required boolean [not null, default: false]
  is_filterable boolean [not null, default: false]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_roles {
  id_rol decimal [pk]
  nom_rol varchar [not null, unique]
  des_rol varchar
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_marcas {
  id_marca decimal [pk]
  nom_marca varchar [not null, unique]
  ind_activo boolean [default: true]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_proveedores {
  id_proveedor decimal [pk]
  nom_proveedor varchar [not null]
  email varchar [not null, unique]
  tel_proveedor decimal [not null]
  ind_activo boolean [default: true]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_products {
  id decimal [pk]
  category_id decimal [not null, ref: > tab_categories.id]
  name varchar [not null]
  slug varchar [not null, unique]
  description text
  id_marca decimal [ref: > tab_marcas.id_marca]
  id_proveedor decimal [ref: > tab_proveedores.id_proveedor]
  is_active boolean [default: true]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_product_variant_groups {
  id bigserial [pk]
  product_id decimal [not null, ref: > tab_products.id]
  dominant_attribute varchar [not null]
  dominant_value varchar [not null]
  is_active boolean [not null, default: true]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_product_variant_combinations {
  id decimal [pk]
  group_id bigint [not null, ref: > tab_product_variant_groups.id]
  sku varchar [not null, unique]
  price decimal [not null]
  stock int [not null, default: 0]
  attributes jsonb [not null]
  is_active boolean [not null, default: true]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_product_variant_images {
  id bigserial [pk]
  variant_group_id bigint [not null, ref: > tab_product_variant_groups.id]
  image_url varchar [not null]
  is_primary boolean [not null, default: false]
  sort_order int [not null, default: 0]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_estadisticas_categorias {
  category_id decimal [pk, ref: - tab_categories.id]
  nom_categoria varchar
  categoria_activa boolean
  total_productos int [default: 0]
  productos_activos int [default: 0]
  productos_con_ventas int [default: 0]
  total_ordenes int [default: 0]
  total_unidades_vendidas int [default: 0]
  total_ingresos decimal [default: 0]
  ventas_mes_actual int [default: 0]
  ingresos_mes_actual decimal [default: 0]
  ventas_mes_anterior int [default: 0]
  ingresos_mes_anterior decimal [default: 0]
