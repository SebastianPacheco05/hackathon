Table tab_descuentos {
  id_descuento decimal [pk]
  nom_descuento varchar [not null]
  des_descuento varchar
  tipo_calculo boolean [not null]
  val_porce_descuento decimal [not null]
  val_monto_descuento decimal [not null]
  aplica_a varchar [not null]
  category_id_aplica decimal [ref: > tab_categories.id]
  product_id_aplica decimal [ref: > tab_products.id]
  id_marca_aplica decimal [ref: > tab_marcas.id_marca]
  min_valor_pedido decimal [default: 0]
  ind_es_para_cumpleanos boolean [default: false]
  fec_inicio date
  fec_fin date
  ind_activo boolean [default: true]
  max_usos_total int
  usos_actuales_total int [default: 0]
  costo_puntos_canje int
  ind_canjeable_puntos boolean [not null, default: false]
  codigo_descuento varchar [unique]
  max_usos_por_usuario int
  dias_semana_aplica varchar
  horas_inicio time
  horas_fin time
  solo_primera_compra boolean [default: false]
  monto_minimo_producto decimal [default: 0]
  cantidad_minima_producto int [default: 1]
  requiere_codigo boolean [default: false]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_descuentos_usuarios {
  id_descuento decimal [not null, ref: > tab_descuentos.id_descuento]
  id_usuario decimal [not null, ref: > tab_usuarios.id_usuario]
