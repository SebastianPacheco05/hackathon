  departamento varchar [not null]
  codigo_postal varchar [not null]
  barrio varchar [not null]
  referencias varchar
  complemento varchar
  ind_principal boolean [not null, default: false]
  ind_activa boolean [not null, default: true]
  usr_insert decimal [not null]
  fec_insert timestamp [not null]
  usr_update decimal
  fec_update timestamp
}

Table tab_metodos_pago_usuario {
  id_metodo_pago serial [pk]
  id_usuario decimal [not null, ref: > tab_usuarios.id_usuario]
  provider_name varchar [not null, default: 'wompi']
  provider_source_id varchar [not null]
  brand varchar
  last_four_digits varchar
  expiration_month int
  expiration_year int
  card_holder varchar
  is_default boolean [not null, default: false]
